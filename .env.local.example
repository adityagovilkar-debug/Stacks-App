# Copy this file to `.env.local` and fill in your Supabase project values.
# Find these in your Supabase dashboard → Project Settings → API.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Optional: the public site URL, used for auth redirect links.
# Defaults to the app origin. Set to your Vercel URL in production.
NEXT_PUBLIC_SITE_URL=http://localhost:3030
